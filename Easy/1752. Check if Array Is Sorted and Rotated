class Solution {
    public boolean check(int[] nums) {
        int check = 0;

        // Step 1: Check the wrap-around boundary (last element to first element)
        if (nums[0] < nums[nums.length - 1]) {
            check++;
        }
        
        // Step 2: Check all adjacent pairs inside the array
        for (int i = 1; i < nums.length; i++) {
            if (nums[i] < nums[i - 1]) {
                check++;
            }
        }

        // Step 3: A valid sorted and rotated array can have at most 1 drop
        return check <= 1;
    }
}
