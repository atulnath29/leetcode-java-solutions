class Solution {
    public int minOperations(String s) {
        int n=s.length();
        int start0=0,start1=0;

        for(int i=0;i<n;i++)
        {
            char c=s.charAt(i);

            if(i%2==0)
            {
                if(c!='0') start0++;
                if(c!='1') start1++;
            }
            else
            {
                if(c!='1') start0++;
                if(c!='0') start1++;
            }
        }

        return Math.min(start0,start1);
    }
}
