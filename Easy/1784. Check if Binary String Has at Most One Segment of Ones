class Solution {
  public boolean checkOnesSegment(String s) {
    int n = s.length();
    int count = 0;

    int i = 0;
    while (i < n) {
      char c = s.charAt(i);
      if (c == '1') {
        count++;
        while (i < n && s.charAt(i) == '1') {
          i++;
        }
      }
      i++;
    }

    return !(count > 1);
  }
}
