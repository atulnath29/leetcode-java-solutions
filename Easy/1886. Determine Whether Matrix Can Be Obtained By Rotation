class Solution {
    private int[][] rotate90 (int[][] matA) {
        int n = matA.length;
        int[][] rs = new int[n][n];
        for(int r = 0 ;r < n; r++)
        for(int c = 0; c < n; c++)
            rs[c][n - 1 - r] = matA[r][c];  
        return rs;
    }
    public boolean findRotation(int[][] mat, int[][] target) {
        int n = mat.length;
        for(int i = 0; i<= 3; i++) {
            boolean rs = true;
            
            out:
            for(int r = 0; r< n; r ++)
            for(int c = 0; c< n; c++) {
                if(mat[r][c] != target[r][c]) {
                    rs = false;
                    break out;
                }
            }
            if(rs == true) return true;
            mat = rotate90(mat);
        }  
        return false;
    }
}
