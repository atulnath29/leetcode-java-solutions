class Solution {
    public int[] separateDigits(int[] nums) {
        ArrayList<Integer> supp = new ArrayList<>();
        for(int i:nums){
            String s = Integer.toString(i);
            char [] arr = s.toCharArray();
            for(char k:arr){
                supp.add(k-'0');
            }
        }
        int [] ans = new int [supp.size()];
        for(int i=0;i<supp.size();i++){
            ans[i] = supp.get(i);
        }
        return ans;
    }
}
