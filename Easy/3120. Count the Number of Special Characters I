class Solution {
    public int numberOfSpecialChars(String word){
        int cnt = 0;
        int[] hashTable = new int[256];
        for(char ch : word.toCharArray()){
            hashTable[ch]++;
        }
        for(int i = 65 ; i <= 90 ; i++){
            if(hashTable[i] != 0 && hashTable[i + 32] != 0){
                cnt++;
            }
        }
        return cnt;
    }
}
