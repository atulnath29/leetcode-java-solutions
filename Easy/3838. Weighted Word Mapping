class Solution {
    public String mapWordWeights(String[] words, int[] weights) {
        int sum;
        char[] arr = "zyxwvutsrqponmlkjihgfedcba".toCharArray();
        String OutputString="";
        for(int i=0;i<words.length;i++){
            sum=0;
            char[] tempWord=words[i].toCharArray();
            for(int j=0;j<tempWord.length;j++){
                sum=sum+(weights[tempWord[j]-97]);
            }
            int modVal=sum%26;
            OutputString+=arr[modVal];

        }
        return OutputString;
    }
}
