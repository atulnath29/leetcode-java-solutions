class Solution {
    String word;
    Map<Integer, int[]> map = Map.ofEntries(
        Map.entry(0, new int[]{0, 0}),
        Map.entry(1, new int[]{0, 1}),
        Map.entry(2, new int[]{0, 2}),
        Map.entry(3, new int[]{0, 3}),
        Map.entry(4, new int[]{0, 4}),
        Map.entry(5, new int[]{0, 5}),
        Map.entry(6, new int[]{1, 0}),
        Map.entry(7, new int[]{1, 1}),
        Map.entry(8, new int[]{1, 2}),
        Map.entry(9, new int[]{1, 3}),
        Map.entry(10, new int[]{1, 4}),
        Map.entry(11, new int[]{1, 5}),
        Map.entry(12, new int[]{2, 0}),
        Map.entry(13, new int[]{2, 1}),
        Map.entry(14, new int[]{2, 2}),
        Map.entry(15, new int[]{2, 3}),
        Map.entry(16, new int[]{2, 4}),
        Map.entry(17, new int[]{2, 5}),
        Map.entry(18, new int[]{3, 0}),
        Map.entry(19, new int[]{3, 1}),
        Map.entry(20, new int[]{3, 2}),
        Map.entry(21, new int[]{3, 3}),
        Map.entry(22, new int[]{3, 4}),
        Map.entry(23, new int[]{3, 5}),
        Map.entry(24, new int[]{4, 0}),
        Map.entry(25, new int[]{4, 1})
    );

    public int minimumDistance(String inputWord) {
        word = inputWord;
        int n = word.length();
        // dp[i][j][k] means for i-th letter, left finger is on letter ('A' + j), right finger is on ('A' + k)
        int[][][] dp = new int[n][27][27];
        for (int i = 0; i < n; i++) {
            for (int j = 0; j < 27; j++) {
                for (int k = 0; k < 27; k++) {
                    dp[i][j][k] = Integer.MAX_VALUE;
                }
            }
        }
        dp[1][num(0)][num(1)] = 0; // left finger is on 0-th letter, right finger is on 1-th letter
        dp[1][num(1)][num(0)] = 0; // left finger is on 1-th letter, right finger is on 0-th letter
        dp[1][num(1)][26] = getDistance(num(0), num(1)); // left finger is on 1-th letter (moved from 0-th to 1-th), right finger is free
        dp[1][26][num(1)] = getDistance(num(0), num(1)); // left finger is free, right finger is on 1-th letter (moved from 0-th to 1-th)
        for (int i = 1; i + 1 < n; i++) { // infer i+1 th based on i-th
            for (int j = 0; j < 27; j++) {
                for (int k = 0; k < 27; k++) {
                    if (dp[i][j][k] == Integer.MAX_VALUE) {
                        continue;
                    }
                    dp[i + 1][num(i + 1)][k] = Math.min(dp[i + 1][num(i + 1)][k], dp[i][j][k] + getDistance(num(i + 1), j));
                    dp[i + 1][j][num(i + 1)] = Math.min(dp[i + 1][j][num(i + 1)], dp[i][j][k] + getDistance(num(i + 1), k));
                }
            }
        }
        int ans = Integer.MAX_VALUE;
        for (int j = 0; j < 27; j++) {
            for (int k = 0; k < 27; k++) {
                ans = Math.min(ans, dp[n - 1][j][k]);
            }
        }
        return ans;
    }

    private int num(int i) {
        return ((int) (word.charAt(i) - 'A'));
    }

    private int getDistance(int x, int y) {
        if (!map.containsKey(x) || !map.containsKey(y)) {
            return 0;
        }
        int[] pointX = map.get(x);
        int[] pointY = map.get(y);
        return Math.abs(pointX[0] - pointY[0]) + Math.abs(pointX[1] - pointY[1]);
    }
}
