class Solution {
    // Changed method name from processString to processStr
    public char processStr(String s, long k) {
        int n = s.length();
        long[] lengths = new long[n];
        long currLen = 0;

        // Step 1: Forward pass to compute string lengths after each operation
        for (int i = 0; i < n; i++) {
            char ch = s.charAt(i);
            if (Character.isLetter(ch)) {
                currLen++;
            } else if (ch == '*') {
                if (currLen > 0) {
                    currLen--;
                }
            } else if (ch == '#') {
                currLen *= 2;
            }
            lengths[i] = currLen;
        }

        // If k is out of bounds of the final constructed string
        if (k >= currLen || k < 0) {
            return '.';
        }

        // Step 2: Backward pass to trace the source of index k
        for (int i = n - 1; i >= 0; i--) {
            char op = s.charAt(i);

            if (op == '%') {
                long len = lengths[i];
                if (len > 0) {
                    k = len - 1 - k;
                }
            } else if (op == '#') {
                long halfLen = lengths[i] / 2;
                if (k >= halfLen) {
                    k -= halfLen;
                }
            } else if (op == '*') {
                continue;
            } else if (Character.isLetter(op)) {
                if (k == lengths[i] - 1) {
                    return op;
                }
            }
        }

        return '.';
    }
}
