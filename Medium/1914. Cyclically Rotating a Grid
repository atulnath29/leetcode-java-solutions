class Solution {
    public int[][] rotateGrid(int[][] grid, int k) {

        int n = grid.length;
        int m = grid[0].length;

        int px1 = 0, py1 = 0, px2 = 0, py2 = m - 1;
        int px3 = n - 1, py3 = m - 1, px4 = n - 1, py4 = 0;

        int[][] ans = new int[n][m];

        while(px1 < px3 && py1 < py2) {

            ArrayList<Integer> temp = new ArrayList<>();

            for(int j = py1; j < py2; j++) temp.add(grid[px1][j]);
            for(int i = px2; i < px3; i++) temp.add(grid[i][py2]);
            for(int j = py3; j > py4; j--) temp.add(grid[px3][j]);
            for(int i = px4; i > px1; i--) temp.add(grid[i][py4]);

            int v = k % temp.size();

            for(int i = 0; i < v; i++) {
                int first = temp.remove(0);
                temp.add(first);
            }

            int idx = 0;

            for(int j = py1; j < py2; j++) ans[px1][j] = temp.get(idx++);
            for(int i = px2; i < px3; i++) ans[i][py2] = temp.get(idx++);
            for(int j = py3; j > py4; j--) ans[px3][j] = temp.get(idx++);
            for(int i = px4; i > px1; i--) ans[i][py4] = temp.get(idx++);

            px1++; py1++;
            px2++; py2--;
            px3--; py3--;
            px4--; py4++;
        }

        return ans;
    }
}
