/**
 * Definition for a binary tree node.
 * public class TreeNode {
 *     int val;
 *     TreeNode left;
 *     TreeNode right;
 *     TreeNode() {}
 *     TreeNode(int val) { this.val = val; }
 *     TreeNode(int val, TreeNode left, TreeNode right) {
 *         this.val = val;
 *         this.left = left;
 *         this.right = right;
 *     }
 * }
 */
class Solution {

    int[] parent = new int[(int)1e5 + 1];

    private int find(int x){
        if(parent[x] == x) return x;
        return parent[x] = find(parent[x]);
    }

    private void union(int a, int b){
        int parent_a = find(a);
        int parent_b = find(b);

        if(parent_a != parent_b){
            parent[parent_b] = parent_a;
        }
    }

    public TreeNode createBinaryTree(int[][] descriptions) {
        for(int i=0;i<parent.length;i++){
            parent[i] = i;
        }
        Map<Integer, TreeNode> map = new HashMap<>();
        TreeNode head = null;

        for(int[] node: descriptions){
            TreeNode curr = map.getOrDefault(node[0], new TreeNode(node[0]));
            TreeNode child = map.getOrDefault(node[1], new TreeNode(node[1]));
            map.put(child.val, child);
            union(curr.val, child.val);
            if(node[2] == 1){
                curr.left = child;
            }else{
                curr.right = child;
            }
            map.put(curr.val, curr);
            int headVal = find(curr.val);
            head = map.get(headVal);
        }
        return head;
    }
}
