class Solution {
    public long[] distance(int[] nums) {
        int n = nums.length;
        long[] res = new long[n];
        HashMap<Integer, ArrayList<Integer>> hm = new HashMap<>();
        for(int i=0;i<n;i++){
            hm.putIfAbsent(nums[i],new ArrayList<>());
            hm.get(nums[i]).add(i);
        }
      for(int i=0;i<n;i++){
        int val = nums[i];
        ArrayList<Integer> al = hm.get(val);
        long ans=0;
        for(int k :al){
            ans += Math.abs(i-k);
        }
        res[i]=ans;
      }  
        return res;
    }
}
