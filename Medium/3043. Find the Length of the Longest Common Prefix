class Solution {
    public int longestCommonPrefix(int[] arr1, int[] arr2) {
        Map<Integer, Integer> m = new HashMap<>();
        int ans = 0;
        for(int i = 0 ; i < arr1.length; i++)
        {
            int temp = arr1[i];
            while(temp > 0)
            {
                m.put(temp,1);
                temp = temp / 10;
            }
        }

        for(int i = 0; i < arr2.length; i++)
        {
            int temp = arr2[i];
            while(temp > 0)
            {
                if(m.containsKey(temp)){
                    int len = 0;
                    while(temp > 0)
                    {
                        temp = temp / 10;
                        len++;
                    }
                    ans = Math.max(ans, len);
                    break;
                } 
                temp = temp / 10;
            }
        }

        return ans;
    }
}
