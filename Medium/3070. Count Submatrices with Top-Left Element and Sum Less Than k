class Solution {
    public int countSubmatrices(int[][] a, int k) {
        int n=a.length;
        int m=a[0].length;
        int[][] p=new int[n+1][m+1];
        int ans=0;
        for(int i=1;i<=n;i++){
            for(int j=1;j<=m;j++){
                p[i][j]=p[i-1][j]+p[i][j-1]+a[i-1][j-1]-p[i-1][j-1];
                if(p[i][j]<=k)ans++;
            }
        }
        return ans;

    }
}
