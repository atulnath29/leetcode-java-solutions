class Solution {
    public int maximumAmount(int[][] coins) {
        int m=coins.length,
            n=coins[0].length;
        
        int minVal=-1000000; // this has been**Bold** set according to the constraints 500 x -1000 and i just doubled that 
        int[][][] dp= new int[3][m+1][n+1];

        for(int i=0;i<=m;i++){
            dp[0][i][0]=minVal;
            dp[1][i][0]=minVal;
            dp[2][i][0]=minVal;
        }
        for(int j=0;j<=m;j++){
            dp[0][0][j]=minVal;
            dp[1][0][j]=minVal;
            dp[2][0][j]=minVal;
        }
        dp[0][0][1]=0;
        dp[0][1][0]=0;

        for(int i=1;i<=m;i++){
            for(int j=1;j<=n;j++){
                int min0=Math.max(dp[0][i-1][j],    dp[0][i][j-1]);
                int min1=Math.max(dp[1][i-1][j],    dp[1][i][j-1]);
                int min2=Math.max(dp[2][i-1][j],    dp[2][i][j-1]);
                int curr=coins[i-1][j-1];
                dp[0][i][j]=curr+min0;
                dp[1][i][j]=Math.max(min0,min1+curr);
                dp[2][i][j]=Math.max(min1,min2+curr);
            }
        }
        // for(int[] row:coins)    System.out.println(Arrays.toString(row));
        // System.out.println();
        // for(int[] row:dp[0])    System.out.println(Arrays.toString(row));
        // System.out.println();
        // for(int[] row:dp[1])    System.out.println(Arrays.toString(row));
        // System.out.println();
        // for(int[] row:dp[2])    System.out.println(Arrays.toString(row));
        // System.out.println();
        return Math.max(dp[0][m][n],Math.max(dp[1][m][n],dp[2][m][n]));
    }
}
