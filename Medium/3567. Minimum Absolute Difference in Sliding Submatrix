class Solution {
    int getAbsDiff(int x, int y, int k, int[][] grid)
    {
        int[] arr =new int[k*k];
        int ans = Integer.MAX_VALUE;
        for(int i = x; i < x+k; i++)
        {
            for(int j = y; j < y + k; j++)
            {
                arr[(i-x)*k + (j-y)] = grid[i][j];
            }
        }

        Arrays.sort(arr);
        int prev = arr[0];
        for(int i = 1; i < k*k; i++)
        {
            if(arr[i-1] != arr[i])
            {
                ans = Math.min(ans, Math.abs(arr[i] - arr[i-1]));
            }
        }
        return (ans == Integer.MAX_VALUE) ? 0 : ans; 
    }
    public int[][] minAbsDiff(int[][] grid, int k) {
        int m = grid.length;
        int n = grid[0].length;

        int[][] result = new int[m-k+1][n-k+1];
        if(k == 1) return result;

        for(int i = 0; i < m - k + 1; i++)
        {
            for(int j = 0; j < n - k + 1; j++)
            {
                result[i][j] = getAbsDiff(i,j,k,grid);
            }
        }
        return result;
    }
}
