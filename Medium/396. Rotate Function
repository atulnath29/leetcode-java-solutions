class Solution {
    public int maxRotateFunction(int[] nums) {
        int n=nums.length;
        long sum=0;
        long t_sum=0;
        for(int i=0;i<n;i++){
            t_sum+=nums[i];
            sum+=(long)(i*nums[i]);
        }
        long ans=sum;
        for(int i=1;i<n;i++){
            sum+=t_sum-nums[n-i]-(n-1)*nums[n-i];
            ans=Math.max(ans,sum);
        }
        return (int)ans;
    }
}
