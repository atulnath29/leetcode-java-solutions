class Solution {
    public void rotate(int[][] arr) {
        int m = arr.length;      // n (matrix is n×n)
        int n = arr[0].length;   // also n

        // ════════════════════════════════════
        // PHASE 1: TRANSPOSE
        // Swap arr[i][j] with arr[j][i]
        // Only upper-left triangle (j < i)
        // to avoid swapping twice
        // ════════════════════════════════════
        for (int i = 0; i < m; i++) {
            for (int j = 0; j < i; j++) {   // ← j < i (not j < m)
                int temp = arr[i][j];
                arr[i][j] = arr[j][i];
                arr[j][i] = temp;
            }
        }

        // ════════════════════════════════════
        // PHASE 2: REVERSE EACH ROW
        // Two-pointer technique per row
        // ════════════════════════════════════
        for (int i = 0; i < m; i++) {
            int a = 0, b = m - 1;           // left & right pointers
            while (a < b) {
                int temp = arr[i][a];
                arr[i][a] = arr[i][b];
                arr[i][b] = temp;
                a++;
                b--;
            }
        }
    }
}
