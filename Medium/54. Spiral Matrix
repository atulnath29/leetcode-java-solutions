class Solution {
    public List<Integer> spiralOrder(int[][] matrix) {
        int m=matrix.length;
            int n=matrix[0].length;
            int row=0,col=0;
            List<Integer> res=new ArrayList<>();
            int r =0;
            int c =1;
            int k=0;
            boolean t=false;
            for(int i=0;i<m*n;i++){
                res.add(matrix[row][col]);
                row+= r;
                col+= c;
                if(col==n-k){   // right boundary
                    row++;
                    col--;
                    c =0;
                    r =1;
                }
                if(row==m-k){   // bottom boundary
                    row--;
                    col--;
                    r =0;
                    c =-1;
                }
                if(col<k){      // left boundary
                    col++;
                    row--;
                    c =0;
                    r =-1;
                    t=true;
                }
                if(t && row==k){ // top boundary
                    r = 0;
                    c = 1;
                    row++;
                    col++;
                    k++;
                    t = false;
                }
            }
        return res;
    }
}
