class Solution {
    public static boolean valid(int num){
        HashSet<Integer> set = new HashSet<>();
        set.add(2);
        set.add(5);
        set.add(6);
        set.add(9);
        boolean v=false;
        while(num!=0){
            int r=num%10;
            if(r==3||r==4){
        return false;
            }
            if(r==7){
                return false;
            }
            if(set.contains(r)){
                v= true;
            }
                num/=10;
            
        }
        if(v){
            return true;
        }
        return false;
    }
    public int rotatedDigits(int n) {
        int count = 0;
        if(n==1){
            return 0;
        }
        for(int i=2;i<=n;i++){
            if(valid(i)){
                count++;
            }
        }
        return count;
    }
}
