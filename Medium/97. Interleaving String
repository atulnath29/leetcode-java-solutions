class Solution {
    public static boolean interleaf(int i, int j, int k, String s1, String s2, String s3, Boolean[][] dp){
        if(i==-1 && j==-1 && k==-1) return true;
        if(k==-1) return false;

        if(dp[i+1][j+1]!=null) return dp[i+1][j+1];
        
        boolean flag = false;
        if(i!=-1 && s1.charAt(i)==s3.charAt(k)) flag = flag || interleaf(i-1,j,k-1,s1,s2,s3,dp);
        if(j!=-1 && s2.charAt(j)==s3.charAt(k)) flag = flag || interleaf(i,j-1,k-1,s1,s2,s3,dp);
        dp[i+1][j+1] = flag;
        return flag;
    }
    public boolean isInterleave(String s1, String s2, String s3) {
        
        int n = s1.length();
        int m = s2.length();
        int o = s3.length();

        Boolean[][] dp= new Boolean[n+1][m+1];
        return interleaf(s1.length()-1,s2.length()-1,s3.length()-1,s1,s2,s3,dp);
    }
}
